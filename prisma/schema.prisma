generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Investment {
  id            String         @id @default(cuid())
  name          String
  ticker        String?
  yahooTicker   String?
  type          InvestmentType
  geography     Geography
  currency      Currency
  sector        String?
  currentPrice  Float
  previousClose Float?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  transactions Transaction[]
}

model Transaction {
  id           String          @id @default(cuid())
  investmentId String
  date         DateTime
  type         TransactionType
  quantity     Float
  pricePerUnit Float
  fees         Float           @default(0)
  notes        String?
  createdAt    DateTime        @default(now())

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
}

model Asset {
  id            String    @id @default(cuid())
  name          String
  description   String?
  type          AssetType
  currency      Currency
  purchaseDate  DateTime
  purchasePrice Float
  currentValue  Float
  notes         String?

  // Property
  location String?
  areaQty  Float?
  areaUnit String? // "sq.ft" | "acres" | "cents" | "grams" | "kg" | "oz" | "tola" | "pieces"

  // Vehicle
  depreciationRate Float? // annual %

  // Cash / FD
  interestRate Float?   // annual %
  maturityDate DateTime?
  principal    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  valuations ValuationEntry[]
}

model ValuationEntry {
  id        String          @id @default(cuid())
  assetId   String
  date      DateTime
  value     Float
  source    ValuationSource
  notes     String?
  createdAt DateTime        @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Settings {
  id           String   @id @default("singleton")
  exchangeRate Float    @default(84)
  updatedAt    DateTime @updatedAt
}

enum InvestmentType {
  INDIA_STOCK
  INDIA_MF
  US_STOCK
  US_ETF
  CRYPTO
  PRIVATE
}

enum Geography {
  INDIA
  US
  OTHER
}

enum Currency {
  INR
  USD
}

enum TransactionType {
  BUY
  SELL
  SIP
  DIVIDEND
}

enum AssetType {
  PROPERTY
  VEHICLE
  CASH_FD
  GOLD_METALS
  ART_COLLECTIBLES
  OTHER
}

enum ValuationSource {
  PURCHASE
  MANUAL
  AUTO_DEPRECIATION
  AUTO_INTEREST
}
